<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.Storyboard.XIB" version="3.0" toolsVersion="21507" targetRuntime="iOS.CocoaTouch" propertyAccessControl="none" useAutolayout="YES" launchScreen="YES" useTraitCollections="YES" initialViewController="viewController">
    <device id="retina6_1" orientation="portrait" appearance="light"/>
    <dependencies>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="21505"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>

    <scenes>
        <!--View Controller-->
        <scene sceneID="scene">
            <objects>
                <viewController id="viewController" sceneMemberID="viewController">
                    <view key="view" contentMode="scaleToFill" id="view">
                        
                        <!-- Background Image -->
                        <imageView clipsSubviews="YES" userInteractionEnabled="NO" contentMode="scaleAspectFill" image="launch_bg" translatesAutoresizingMaskIntoConstraints="NO" id="bgImage">
                        </imageView>

                       
                        <constraints>
                            <!-- Background constraints -->
                            <constraint firstItem="bgImage" firstAttribute="top" secondItem="view" secondAttribute="top" id="bg-top"/>
                            <constraint firstItem="bgImage" firstAttribute="bottom" secondItem="view" secondAttribute="bottom" id="bg-bottom"/>
                            <constraint firstItem="bgImage" firstAttribute="leading" secondItem="view" secondAttribute="leading" id="bg-leading"/>
                            <constraint firstItem="bgImage" firstAttribute="trailing" secondItem="view" secondAttribute="trailing" id="bg-trailing"/>
                        </constraints>

                        <color key="backgroundColor" systemColor="systemBackgroundColor"/>
                    </view>
                </viewController>
                <placeholder placeholderIdentifier="IBFirstResponder" id="firstResponder" sceneMemberID="firstResponder"/>
            </objects>
        </scene>
    </scenes>

    <resources>
        <image name="launch_bg" width="375" height="812"/>
        <image name="logo" width="180" height="80"/>
    </resources>
</document>//
